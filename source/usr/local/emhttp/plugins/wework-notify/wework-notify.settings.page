<?php
$plugin = "wework-notify";
$cfg = parse_plugin_cfg($plugin);
$csrf_token = $var['csrf_token'] ?? '';

// Defaults for new install
$use_wework      = $cfg['USE_WEWORK']           ?? 'no';
$app_name        = $cfg['APP_NAME']             ?? 'Unraid Server';
$webhook_url     = $cfg['WEWORK_WEBHOOK_URL']   ?? '';
$title_event     = $cfg['TITLE_EVENT']          ?? 'no';
$title_subject   = $cfg['TITLE_SUBJECT']        ?? 'yes';
$title_timestamp = $cfg['TITLE_TIMESTAMP']      ?? 'no';
$title_desc      = $cfg['TITLE_DESCRIPTION']    ?? 'yes';
$title_important = $cfg['TITLE_IMPORTANCE']     ?? 'no';
$title_content   = $cfg['TITLE_CONTENT']        ?? 'no';
$title_link      = $cfg['TITLE_LINK']           ?? 'no';
$msg_event       = $cfg['MESSAGE_EVENT']        ?? 'no';
$msg_subject     = $cfg['MESSAGE_SUBJECT']      ?? 'no';
$msg_timestamp   = $cfg['MESSAGE_TIMESTAMP']    ?? 'no';
$msg_desc        = $cfg['MESSAGE_DESCRIPTION']  ?? 'yes';
$msg_important   = $cfg['MESSAGE_IMPORTANCE']   ?? 'no';
$msg_content     = $cfg['MESSAGE_CONTENT']      ?? 'no';
$msg_link        = $cfg['MESSAGE_LINK']         ?? 'no';
?>

<form markdown="1" method="POST" action="/update.php" target="progressFrame">
<input type="hidden" name="#file" value="<?=$plugin?>/<?=$plugin?>.cfg">

_(Enable WeWork Notify)_:
: <select name="USE_WEWORK" size="1">
  <option value="yes" <?=$use_wework=='yes'?'selected':''?>>_(Yes)_</option>
  <option value="no"  <?=$use_wework=='no'?'selected':''?>>_(No)_</option>
</select>

_(Application name)_:
: <input type="text" name="APP_NAME" value="<?=htmlspecialchars($app_name)?>" placeholder="Unraid Server">

_(Webhook URL)_:
: <input type="text" name="WEWORK_WEBHOOK_URL" value="<?=htmlspecialchars($webhook_url)?>" placeholder="https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=...">

_(Notification title)_:
: <input type="checkbox" name="TITLE_EVENT"     value="yes" <?=$title_event=='yes'?'checked':''?>>_(Event)_
: <input type="checkbox" name="TITLE_SUBJECT"   value="yes" <?=$title_subject=='yes'?'checked':''?>>_(Subject)_ _(default)_
: <input type="checkbox" name="TITLE_TIMESTAMP" value="yes" <?=$title_timestamp=='yes'?'checked':''?>>_(Timestamp)_
: <input type="checkbox" name="TITLE_DESCRIPTION" value="yes" <?=$title_desc=='yes'?'checked':''?>>_(Description)_
: <input type="checkbox" name="TITLE_IMPORTANCE" value="yes" <?=$title_important=='yes'?'checked':''?>>_(Importance)_
: <input type="checkbox" name="TITLE_CONTENT" value="yes" <?=$title_content=='yes'?'checked':''?>>_(Content)_
: <input type="checkbox" name="TITLE_LINK"    value="yes" <?=$title_link=='yes'?'checked':''?>>_(Link)_

_(Notification message)_:
: <input type="checkbox" name="MESSAGE_EVENT"     value="yes" <?=$msg_event=='yes'?'checked':''?>>_(Event)_
: <input type="checkbox" name="MESSAGE_SUBJECT"   value="yes" <?=$msg_subject=='yes'?'checked':''?>>_(Subject)_
: <input type="checkbox" name="MESSAGE_TIMESTAMP" value="yes" <?=$msg_timestamp=='yes'?'checked':''?>>_(Timestamp)_
: <input type="checkbox" name="MESSAGE_DESCRIPTION" value="yes" <?=$msg_desc=='yes'?'checked':''?>>_(Description)_ _(default)_
: <input type="checkbox" name="MESSAGE_IMPORTANCE" value="yes" <?=$msg_important=='yes'?'checked':''?>>_(Importance)_
: <input type="checkbox" name="MESSAGE_CONTENT" value="yes" <?=$msg_content=='yes'?'checked':''?>>_(Content)_
: <input type="checkbox" name="MESSAGE_LINK"    value="yes" <?=$msg_link=='yes'?'checked':''?>>_(Link)_

<hr>

<button type="button" onclick="testNotification()">_(Test Notification)_</button>
<span id="testResult" style="margin-left:12px;font-weight:600;"></span>

<script>
function testNotification() {
    var url = document.getElementsByName('WEWORK_WEBHOOK_URL')[0].value;
    if (!url) {
        document.getElementById('testResult').innerHTML = '<span style="color:#e68a00;">Please enter a webhook URL first</span>';
        return;
    }
    document.getElementById('testResult').innerHTML = '<span style="color:#0078d4;">Sending test...</span>';
    var xhr = new XMLHttpRequest();
    xhr.open('POST', '/plugins/wework-notify/test.php', true);
    xhr.setRequestHeader('Content-Type', 'application/x-www-form-urlencoded');
    xhr.onload = function() {
        if (xhr.status === 200) {
            try {
                var resp = JSON.parse(xhr.responseText);
                if (resp.errcode === 0) {
                    document.getElementById('testResult').innerHTML = '<span style="color:#107c10;">Test sent successfully! Check WeWork</span>';
                } else {
                    document.getElementById('testResult').innerHTML = '<span style="color:#d13438;">WeWork returned error: ' + resp.errmsg + '</span>';
                }
            } catch(e) {
                document.getElementById('testResult').innerHTML = '<span style="color:#d13438;">Failed to parse response</span>';
            }
        } else {
            document.getElementById('testResult').innerHTML = '<span style="color:#d13438;">Connection failed (HTTP ' + xhr.status + ')</span>';
        }
    };
    xhr.onerror = function() {
        document.getElementById('testResult').innerHTML = '<span style="color:#d13438;">Network error - check webhook URL</span>';
    };
    xhr.send('url=' + encodeURIComponent(url) + '&csrf_token=<?=$csrf_token?>');
}
</script>

<input type="submit" name="#default" value="_(Default)_">
: <input type="submit" name="#apply" value="_(Apply)_" disabled><input type="button" value="_(Done)_" onclick="done()">
</form>
