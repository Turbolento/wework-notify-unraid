#!/bin/bash
# WeWork Notification Agent for Unraid
# Receives notification data via environment variables from Unraid's notify system
# Sends to WeWork (дјҒдёҡеҫ®дҝЎ) group chat via webhook using markdown_v2 format
#
# Config file: /boot/config/plugins/wework-notify/wework-notify.cfg
# Log file:    /var/log/notify_wework

SCRIPTNAME=$(basename "${0}")
LOG="/var/log/notify_${SCRIPTNAME}"

# в”Җв”Җ Quick test defaults (mimics notify script) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
[[ -z "${EVENT}"       ]] && EVENT='Unraid Status'
[[ -z "${SUBJECT}"     ]] && SUBJECT='Notification'
[[ -z "${DESCRIPTION}" ]] && DESCRIPTION='No description'
[[ -z "${IMPORTANCE}"  ]] && IMPORTANCE='normal'
[[ -z "${TIMESTAMP}"   ]] && TIMESTAMP=$(date +%s)

# в”Җв”Җ Read config в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
CONFIG_FILE="/boot/config/plugins/wework-notify/wework-notify.cfg"
if [ ! -f "$CONFIG_FILE" ]; then
    exit 0
fi
. "$CONFIG_FILE"

# в”Җв”Җ Check if enabled в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
if [ "$USE_WEWORK" != "yes" ]; then
    exit 0
fi

if [ -z "$WEWORK_WEBHOOK_URL" ]; then
    exit 0
fi

# в”Җв”Җ Default checkbox values в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
APP_NAME="${APP_NAME:-Unraid Server}"
TITLE_SUBJECT="${TITLE_SUBJECT:-yes}"
TITLE_DESCRIPTION="${TITLE_DESCRIPTION:-yes}"
MESSAGE_DESCRIPTION="${MESSAGE_DESCRIPTION:-yes}"

# в”Җв”Җ Map importance to emoji в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
case "$IMPORTANCE" in
    normal)  EMOJI="рҹ”ө" ;;
    warning) EMOJI="вҡ пёҸ" ;;
    alert)   EMOJI="рҹҡЁ" ;;
    *)       EMOJI="рҹ”ө" ;;
esac

# в”Җв”Җ Helper: read checkbox field, return value if "yes" в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
checked() {
    local varname="$1"
    local value="${!varname}"
    if [ "$value" = "yes" ]; then
        echo "$2"
    fi
}

# в”Җв”Җ Format timestamp в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
FORMATTED_TIME=$(date -d @"${TIMESTAMP}" '+%Y-%m-%d %H:%M:%S' 2>/dev/null || date -r "${TIMESTAMP}" '+%Y-%m-%d %H:%M:%S' 2>/dev/null || echo '')

# в”Җв”Җ Build the notification title line в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
TITLE_PARTS=""
[ -n "$(checked TITLE_EVENT "${EVENT}")"            ] && TITLE_PARTS="${TITLE_PARTS}[${EVENT}] "
[ -n "$(checked TITLE_SUBJECT "${SUBJECT}")"        ] && TITLE_PARTS="${TITLE_PARTS}${SUBJECT}"
[ -n "$(checked TITLE_TIMESTAMP "${FORMATTED_TIME}")" ] && TITLE_PARTS="${TITLE_PARTS} (${FORMATTED_TIME})"
[ -n "$(checked TITLE_DESCRIPTION "${DESCRIPTION}")" ] && TITLE_PARTS="${TITLE_PARTS} - ${DESCRIPTION}"
[ -n "$(checked TITLE_IMPORTANCE "${IMPORTANCE}")"   ] && TITLE_PARTS="${TITLE_PARTS} [${IMPORTANCE}]"
[ -n "$(checked TITLE_CONTENT "${CONTENT}")"          ] && TITLE_PARTS="${TITLE_PARTS} | ${CONTENT}"

# If title is empty, use subject as fallback
if [ -z "$TITLE_PARTS" ]; then
    TITLE_PARTS="${SUBJECT}"
fi

# в”Җв”Җ Build the message body в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
MSG_PARTS=""
[ -n "$(checked MESSAGE_EVENT "${EVENT}")"               ] && MSG_PARTS="${MSG_PARTS}**дәӢд»¶**: ${EVENT}\n"
[ -n "$(checked MESSAGE_SUBJECT "${SUBJECT}")"           ] && MSG_PARTS="${MSG_PARTS}**дё»йўҳ**: ${SUBJECT}\n"
[ -n "$(checked MESSAGE_TIMESTAMP "${FORMATTED_TIME}")"  ] && MSG_PARTS="${MSG_PARTS}**ж—¶й—ҙ**: ${FORMATTED_TIME}\n"
[ -n "$(checked MESSAGE_DESCRIPTION "${DESCRIPTION}")"   ] && MSG_PARTS="${MSG_PARTS}**жҸҸиҝ°**: ${DESCRIPTION}\n"
[ -n "$(checked MESSAGE_IMPORTANCE "${IMPORTANCE}")"     ] && MSG_PARTS="${MSG_PARTS}**зә§еҲ«**: ${IMPORTANCE}\n"
[ -n "$(checked MESSAGE_CONTENT "${CONTENT}")"            ] && MSG_PARTS="${MSG_PARTS}${CONTENT}\n"

# в”Җв”Җ Build markdown_v2 content в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
MD_CONTENT="## ${EMOJI} ${APP_NAME}\n> ${TITLE_PARTS}"

if [ -n "$MSG_PARTS" ]; then
    MD_CONTENT="${MD_CONTENT}\n${MSG_PARTS}"
fi

# Append link if enabled and present
if [ -n "$LINK" ]; then
    if [ "$(checked TITLE_LINK "")" != "" ] || [ "$(checked MESSAGE_LINK "")" != "" ]; then
        MD_CONTENT="${MD_CONTENT}> [жҹҘзңӢиҜҰжғ…](${LINK})\n"
    fi
fi

# в”Җв”Җ JSON-escape the content в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
JSON_CONTENT=$(printf '%s' "$MD_CONTENT" | sed \
    -e 's/\\/\\\\/g' \
    -e 's/"/\\"/g' \
    -e ':a' -e 'N' -e '$!ba' -e 's/\n/\\n/g')

# в”Җв”Җ Build payload в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
PAYLOAD="{\"msgtype\":\"markdown_v2\",\"markdown_v2\":{\"content\":\"${JSON_CONTENT}\"}}"

# в”Җв”Җ Send with retry в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
MAX=3
for ((i = 1; i <= MAX; i++)); do
    RET=$(curl -s -X POST \
        -H "Content-Type: application/json" \
        -d "$PAYLOAD" \
        --connect-timeout 5 \
        --max-time 10 \
        "$WEWORK_WEBHOOK_URL" 2>&1)

    # If nothing returned, message was sent successfully
    [[ -z "$RET" ]] && break

    # If response contains errcode=0, success
    echo "$RET" | grep -q '"errcode":0' && break

    # Log failure
    {
        date
        echo "attempt ${i} of ${MAX} failed"
        echo "$RET"
    } >> "$LOG"

    # If not rate-limited, don't retry
    echo "$RET" | grep -q '"errcode":45009' || break

    sleep 1
done

exit 0
