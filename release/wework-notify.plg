<?xml version="1.0" standalone="yes"?>
<!DOCTYPE PLUGIN [
<!ENTITY name "wework-notify">
<!ENTITY author "Turbolento">
<!ENTITY version "2026.07.29">
<!ENTITY launch "Settings/Notifications">
<!ENTITY pluginURL "https://raw.githubusercontent.com/Turbolento/wework-notify-unraid/master/wework-notify.plg">
<!ENTITY packageURL "https://raw.githubusercontent.com/Turbolento/wework-notify-unraid/master/release/wework-notify.txz">
<!ENTITY source "/boot/config/plugins/&name;/&name;">
]>
<PLUGIN name="&name;" author="&author;" version="&version;" launch="&launch;" pluginURL="&pluginURL;" icon="wework-notify.png" min="6.12.0" support="https://forums.unraid.net/" project="https://github.com/Turbolento/wework-notify-unraid">

<CHANGES>
###&version;
- Full cleanup on remove (no config preservation)
- Fresh .sh from template on install
- LF line endings in all files
###2026.07.23
- eval-based test faker
</CHANGES>

<FILE Run="/bin/bash">
<INLINE>
rm -f /var/log/plugins/&name;.plg /var/log/plugins/&name;.txz /var/log/plugins/&name;.md5
mkdir -p /boot/config/plugins/&name;
mkdir -p /boot/config/plugins/dynamix/notifications/agents
mkdir -p /boot/config/plugins/dynamix/notifications/agents-disabled
</INLINE>
</FILE>

<FILE Name="&source;.txz" Run="/bin/bash">
<INLINE>
tar -xJf /boot/config/plugins/wework-notify/wework-notify.txz -C / 2>/dev/null
</INLINE>
<URL>&packageURL;</URL>
</FILE>

<FILE Run="/bin/bash">
<INLINE>
# Clean old formats
rm -f /boot/config/plugins/dynamix/notifications/agents/wework
rm -f /boot/config/plugins/dynamix/notifications/agents/wework.sh
rm -f /boot/config/plugins/dynamix/notifications/agents-disabled/wework
rm -f /boot/config/plugins/dynamix/notifications/agents-disabled/wework.sh
# Fresh initial agent (disabled, user enables via UI)
# XML (wework.xml) is the single source for the agent script.
# No .sh pre-created -- user clicks Apply in UI to generate from XML.

echo ""
echo "-----------------------------------------------------------"
echo " WeWork Notify v&version; installed"
echo " Settings -> Notification Settings -> Notification Agents -> WeWork"
echo "-----------------------------------------------------------"
echo ""
</INLINE>
</FILE>

<FILE Run="/bin/bash" Method="remove">
<INLINE>
removepkg &name; 2>/dev/null
rm -f /var/log/plugins/&name;.plg /var/log/plugins/&name;.txz /var/log/plugins/&name;.md5
rm -f /boot/config/plugins/dynamix/notifications/agents/wework.sh
rm -f /boot/config/plugins/dynamix/notifications/agents/wework
rm -f /boot/config/plugins/dynamix/notifications/agents-disabled/wework.sh
rm -f /boot/config/plugins/dynamix/notifications/agents-disabled/wework
rm -f /usr/local/emhttp/plugins/dynamix/agents/wework.xml
rm -f /usr/local/emhttp/plugins/dynamix/icons/wework.png
echo "WeWork Notify removed."
</INLINE>
</FILE>

</PLUGIN>
