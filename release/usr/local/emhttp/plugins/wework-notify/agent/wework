#!/bin/bash
# WeWork Notification Agent for Unraid
# Receives notification data via environment variables
# Sends to WeWork (企业微信) group chat via webhook (markdown_v2)

SCRIPTNAME=$(basename "${0}")
LOG="/var/log/notify_${SCRIPTNAME}"

# Quick test defaults (mimics notify script)
[[ -z "${EVENT}"       ]] && EVENT='Unraid Status'
[[ -z "${SUBJECT}"     ]] && SUBJECT='Notification'
[[ -z "${DESCRIPTION}" ]] && DESCRIPTION='No description'
[[ -z "${IMPORTANCE}"  ]] && IMPORTANCE='normal'
[[ -z "${TIMESTAMP}"   ]] && TIMESTAMP=$(date +%s)

# Detect test run: if all three main fields are identical "X test.", fake real data
if [ "$EVENT" = "$SUBJECT" ] && [ "$SUBJECT" = "$DESCRIPTION" ]; then
    EVENT="Array Start"
    SUBJECT="Array started successfully"
    DESCRIPTION="Array has been started"
    CONTENT="All disks mounted normally. Parity is valid."
    IMPORTANCE="normal"
    TIMESTAMP="${TIMESTAMP:-$(date +%s)}"
fi

CONFIG_FILE="/boot/config/plugins/wework-notify/wework-notify.cfg"
if [ ! -f "$CONFIG_FILE" ]; then exit 0; fi
. "$CONFIG_FILE"

if [ "$USE_WEWORK" != "yes" ]; then exit 0; fi
if [ -z "$WEWORK_WEBHOOK_URL" ]; then exit 0; fi

APP_NAME="${APP_NAME:-Unraid Server}"
TITLE_SUBJECT="${TITLE_SUBJECT:-yes}"
MESSAGE_DESCRIPTION="${MESSAGE_DESCRIPTION:-yes}"

case "$IMPORTANCE" in
    normal)  EMOJI="🔵" ;;
    warning) EMOJI="⚠️" ;;
    alert)   EMOJI="🚨" ;;
    *)       EMOJI="🔵" ;;
esac

checked() { local val="${!1}"; [ "$val" = "yes" ] && echo "$2"; }

# Format timestamp
TS=$(date -d @"${TIMESTAMP}" '+%Y-%m-%d %H:%M:%S' 2>/dev/null || date -r "${TIMESTAMP}" '+%Y-%m-%d %H:%M:%S' 2>/dev/null || echo '')
[ -n "$TS" ] && TIMESTAMP="$TS"

# Build title
TITLE_PARTS=""
[ -n "$(checked TITLE_EVENT "${EVENT}")"            ] && TITLE_PARTS="${TITLE_PARTS}[${EVENT}] "
[ -n "$(checked TITLE_SUBJECT "${SUBJECT}")"        ] && TITLE_PARTS="${TITLE_PARTS}${SUBJECT}"
[ -n "$(checked TITLE_TIMESTAMP "${TIMESTAMP}")"    ] && TITLE_PARTS="${TITLE_PARTS} (${TIMESTAMP})"
[ -n "$(checked TITLE_DESCRIPTION "${DESCRIPTION}")" ] && TITLE_PARTS="${TITLE_PARTS} - ${DESCRIPTION}"
[ -n "$(checked TITLE_IMPORTANCE "${IMPORTANCE}")"   ] && TITLE_PARTS="${TITLE_PARTS} [${IMPORTANCE}]"
[ -n "$(checked TITLE_CONTENT "${CONTENT}")"          ] && TITLE_PARTS="${TITLE_PARTS} | ${CONTENT}"
[ -z "$TITLE_PARTS" ] && TITLE_PARTS="${SUBJECT}"

# Build message body
MSG_PARTS=""
[ -n "$(checked MESSAGE_EVENT "${EVENT}")"               ] && MSG_PARTS="${MSG_PARTS}> **事件**: ${EVENT}\n"
[ -n "$(checked MESSAGE_SUBJECT "${SUBJECT}")"           ] && MSG_PARTS="${MSG_PARTS}> **主题**: ${SUBJECT}\n"
[ -n "$(checked MESSAGE_TIMESTAMP "${TIMESTAMP}")"       ] && MSG_PARTS="${MSG_PARTS}> **时间**: ${TIMESTAMP}\n"
[ -n "$(checked MESSAGE_DESCRIPTION "${DESCRIPTION}")"   ] && MSG_PARTS="${MSG_PARTS}> **描述**: ${DESCRIPTION}\n"
[ -n "$(checked MESSAGE_IMPORTANCE "${IMPORTANCE}")"     ] && MSG_PARTS="${MSG_PARTS}> **级别**: ${IMPORTANCE}\n"
[ -n "$(checked MESSAGE_CONTENT "${CONTENT}")"            ] && MSG_PARTS="${MSG_PARTS}> ${CONTENT}\n"

NL=$'\n'

MD="## ${EMOJI} [${IMPORTANCE}] ${APP_NAME}${NL}> ${TITLE_PARTS}"

if [ -n "$MSG_PARTS" ]; then
    MSG_FORMATTED=$(printf '%b' "$MSG_PARTS" | sed '/./s/^/> /')
    MD="${MD}${NL}${MSG_FORMATTED}"
fi

if [ -n "$LINK" ]; then
    if [ "$(checked TITLE_LINK "")" != "" ] || [ "$(checked MESSAGE_LINK "")" != "" ]; then
        MD="${MD}${NL}> [查看详情](${LINK})"
    fi
fi

ESCAPED=$(printf '%s' "$MD" | sed ':a;N;$!ba;s/\\/\\\\/g;s/"/\\"/g;s/\n/\\n/g')
PAYLOAD="{\"msgtype\":\"markdown_v2\",\"markdown_v2\":{\"content\":\"${ESCAPED}\"}}"

MAX=3
for ((i = 1; i <= MAX; i++)); do
    RET=$(curl -s -X POST -H "Content-Type: application/json" -d "$PAYLOAD" \
        --connect-timeout 5 --max-time 10 "$WEWORK_WEBHOOK_URL" 2>&1)
    [[ -z "$RET" ]] && break
    echo "$RET" | grep -q '"errcode":0' && break
    { date; echo "attempt ${i} of ${MAX} failed"; echo "$RET"; } >> "$LOG"
    echo "$RET" | grep -q '"errcode":45009' || break
    sleep 1
done

exit 0
